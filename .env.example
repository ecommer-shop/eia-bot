CHATWOOT_API_TOKEN=tu_access_token_de_chatwoot
CHATWOOT_ACCOUNT_ID=1

# ─── RAG ────────────────────────────────────────────────
RAG_BASE_URL=https://simetria.ecommer.shop

# ─── Azure Phi-4 (fallback si el RAG falla) ─────────────
